{
  "name": "obsidian-remark-bridge",
  "version": "0.1.5",
  "description": "Push notes to your reMarkable tablet via reMark Bridge",
  "main": "main.js",
  "scripts": {
    "dev": "esbuild main.ts --bundle --external:obsidian --format=cjs --target=es2018 --outfile=main.js --watch",
    "build": "esbuild main.ts --bundle --external:obsidian --format=cjs --target=es2018 --minify --outfile=main.js",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian-plugin",
    "remarkable",
    "sync"
  ],
  "author": "BGGBTAC",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20",
    "@typescript-eslint/parser": "^8.58.2",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.25",
    "eslint": "^9.39.4",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-obsidianmd": "^0.2.3",
    "obsidian": "latest",
    "tslib": "^2.6",
    "typescript": "^5.4"
  }
}
